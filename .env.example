# Group 6: Fanin-Fanout Environment Variables
# This file contains placeholder values for all environment variables used by the Group 6 (fanin-fanout) project.

# --- Docker Compose Configuration ---
# Port for the metrics-service API (default: 8086)
# Used as: "${METRICS_PORT:-8080}:8080"
METRICS_PORT=8086
# Port for the Grafana dashboard (default: 3006)
# Used as: "${GRAFANA_PORT:-3000}:3000"
GRAFANA_PORT=3006
# Port for the PostgreSQL database (default: 5436)
# Used as: "${POSTGRES_PORT:-5436}:5432"
POSTGRES_PORT=5436

# --- Host Paths ---
# Host directory containing the Java source code to be scanned (mapped to /input in container)
INPUT_DIR=./input
# Host directory for Grafana provisioning data (datasources, dashboards)
GRAFANA_PROVISIONING_DIR=./grafana/provisioning

# --- PostgreSQL Credentials ---
# These are used to initialize the Postgres container and by Grafana to connect
POSTGRES_USER=grafana
POSTGRES_PASSWORD=grafana
POSTGRES_DB=metrics

# --- Grafana Configuration ---
# Admin credentials for the Grafana web UI
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
# Plugins to install in Grafana
GF_INSTALL_PLUGINS=marcusolsson-json-datasource

# --- Java Application Configuration (Metrics Service) ---
# JDBC Connection details for the application to write to the database
JDBC_URL=jdbc:postgresql://localhost:5436/metrics
JDBC_USER=grafana
JDBC_PASSWORD=grafana

# Port for the internal Javalin server (defaults to 8080 if not set, mapped via METRICS_PORT)
PORT=8080

# --- Pipeline & CLI Configuration ---
# Path for the metric pipeline to scan (used by MetricPipelineMain)
# In Docker, this is usually set to /input
INPUT_PATH=./input
# Directory where generated metrics (CSV/JSON) are saved by the CLI
OUTPUT_DIR=metrics-output
