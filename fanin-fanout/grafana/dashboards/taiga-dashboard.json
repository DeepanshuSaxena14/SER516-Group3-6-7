            "gridPos": {
                "h": 10,
                "w": 24,
                "x": 0,
                "y": 14
            },
            "id": 6,
            "options": {
                "cellHeight": "sm",
                "showHeader": true,
                "sortBy": [
                    {
                        "desc": true,
                        "displayName": "Recorded At"
                    }
                ]
            },
            "pluginVersion": "12.3.2",
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  ff.created_at                                         AS \"Recorded At\",\n  ff.total_velocity                                     AS \"Velocity\",\n  ff.total_story_points                                 AS \"Total Story Points\",\n  a.days_list                                           AS \"Sprint Duration (days)\",\n  ROUND(\n    CASE WHEN a.days_list = 0 THEN 0\n         ELSE a.storypoints::numeric / a.days_list\n    END, 2\n  )                                                     AS \"Avg Pts/Day\",\n  a.business_value                                      AS \"Business Value\"\nFROM \"Focus Factor\" ff\nJOIN \"AUC\" a ON ff.run_id = a.run_id\nORDER BY ff.created_at DESC;",
                    "refId": "A"
                }
            ],
            "title": "Sprint Summary Table (Velocity / Story Points / Duration)",
            "type": "table"
        }
