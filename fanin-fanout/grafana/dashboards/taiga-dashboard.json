                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT ROUND(\n  CASE WHEN days_list = 0 THEN 0\n       ELSE storypoints::numeric / days_list\n  END, 2\n) AS \"Avg Story Points / Day\"\nFROM \"AUC\"\nORDER BY created_at DESC\nLIMIT 1;",
                    "refId": "A"
                }
            ],
            "title": "Avg Story Points per Sprint Day",
            "type": "stat"
