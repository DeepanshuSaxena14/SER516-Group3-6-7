            "pluginVersion": "12.3.2",
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT total_velocity AS \"Sprint Velocity\"\nFROM \"Focus Factor\"\nORDER BY created_at DESC\nLIMIT 1;",
                    "refId": "A"
                }
            ],
            "title": "Latest Sprint Velocity",
            "type": "stat"
        },
