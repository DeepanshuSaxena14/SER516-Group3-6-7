        {
            "datasource": {
                "type": "grafana-postgresql-datasource",
                "uid": "postgres-metrics"
            },
            "description": "Full sprint history joining Focus Factor and AUC tables on run_id.",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "custom": {
