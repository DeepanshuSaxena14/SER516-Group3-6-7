      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-metrics"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  100.0 * MAX(CASE WHEN metric = 'jvm_heap_used_bytes' THEN value END)\n        / NULLIF(MAX(CASE WHEN metric = 'jvm_heap_max_bytes' THEN value END), 0)\n  AS \"Heap %\"\nFROM observability_metrics\nWHERE service = 'g6-metrics'\n  AND metric IN ('jvm_heap_used_bytes','jvm_heap_max_bytes')\n  AND scraped_at >= NOW() - INTERVAL '1 minute';",
          "refId": "A"
        }
      ],
      "title": "g6-metrics — Heap Utilisation %",
      "type": "gauge"
