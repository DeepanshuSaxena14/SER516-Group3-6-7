      "title": "Node.js Event Loop Lag — middleware & g7-pmd",
      "type": "row"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres-metrics"
      },
      "description": "Event loop lag percentiles for middleware and g7-pmd. High p99 values mean the event loop is blocked.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-metrics"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT scraped_at AS \"time\", service || ' ' || metric AS metric, value\nFROM observability_metrics\nWHERE metric IN ('eventloop_lag_p50_seconds','eventloop_lag_p95_seconds','eventloop_lag_p99_seconds')\n  AND service IN ('middleware','g7-pmd')\n  AND scraped_at BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY scraped_at;",
          "refId": "A"
        }
      ],
      "title": "Event Loop Lag — middleware & g7-pmd (p50 / p95 / p99)",
      "type": "timeseries"
    },
