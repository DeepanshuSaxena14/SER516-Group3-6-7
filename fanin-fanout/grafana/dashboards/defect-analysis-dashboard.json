            "id": 10,
            "title": "Total Defects",
            "description": "Total number of code violations found in the latest analysis run.",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres-metrics"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
