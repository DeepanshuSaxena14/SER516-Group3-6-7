            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT COUNT(*) AS \"Critical Defects\"\nFROM pmd_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM pmd_metrics)\n  AND priority <= 2;",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 12,
            "title": "Total Files Analyzed",
