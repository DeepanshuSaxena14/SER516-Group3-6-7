        {
            "id": 1,
            "title": "Defects per File (Bar Chart)",
            "description": "Displays violation counts for each file from the latest analysis run. Files are sorted by violation count descending.",
            "type": "barchart",
            "gridPos": {
                "h": 12,
                "w": 24,
                "x": 0,
                "y": 4
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres-metrics"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "axisBorderShow": false,
                        "axisCenteredZero": false,
                        "axisLabel": "Defect Count",
                        "axisPlacement": "auto",
                        "fillOpacity": 80,
                        "gradientMode": "scheme",
                        "lineWidth": 1,
                        "scaleDistribution": {
                            "type": "linear"
                        }
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 10
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "barWidth": 0.7,
                "groupWidth": 0.7,
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "orientation": "horizontal",
                "showValue": "always",
                "stacking": "none",
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                },
                "xTickLabelRotation": 0
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT file_name AS \"File\", COUNT(*) AS \"Defects\"\nFROM pmd_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM pmd_metrics)\n  AND priority <= ${min_priority}\n  AND file_name LIKE '%${file_filter}%'\nGROUP BY file_name\nORDER BY \"Defects\" DESC;",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 2,
            "title": "Defects Metrics Table",
            "description": "Detailed list of violations from the latest run.",
            "type": "table",
            "gridPos": {
                "h": 10,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres-metrics"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "custom": {
                        "align": "auto",
                        "cellOptions": {
                            "type": "auto"
                        },
                        "inspect": false
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 5
                            },
                            {
                                "color": "red",
                                "value": 10
                            }
                        ]
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Defects"
                        },
                        "properties": [
                            {
                                "id": "custom.cellOptions",
                                "value": {
                                    "mode": "gradient",
                                    "type": "gauge"
                                }
                            },
                            {
                                "id": "min",
                                "value": 0
                            },
                            {
                                "id": "max",
                                "value": 20
                            }
                        ]
                    }
                ]
            },
            "options": {
                "showHeader": true,
                "cellHeight": "sm",
                "footer": {
                    "show": false
                },
                "sortBy": [
                    {
                        "desc": true,
                        "displayName": "Defects"
                    }
                ]
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT file_name AS \"File\", rule AS \"Rule\", priority AS \"Priority\"\nFROM pmd_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM pmd_metrics)\n  AND priority <= ${min_priority}\n  AND file_name LIKE '%${file_filter}%'\nORDER BY priority ASC, file_name ASC;",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 3,
            "title": "Defects Trend Over Time",
            "description": "Shows how total defect count changes across analysis runs.",
            "type": "timeseries",
            "gridPos": {
                "h": 10,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "datasource": {
                "type": "postgres",
                "uid": "postgres-metrics"
