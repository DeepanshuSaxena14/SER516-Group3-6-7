                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT COUNT(DISTINCT file_name) AS \"Files\"\nFROM pmd_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM pmd_metrics);",
                    "refId": "A"
