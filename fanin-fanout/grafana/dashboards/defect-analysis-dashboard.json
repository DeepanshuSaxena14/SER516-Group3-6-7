                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-metrics"
                    },
                    "editorMode": "code",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT COUNT(*) AS \"Total Defects\"\nFROM pmd_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM pmd_metrics);",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 11,
