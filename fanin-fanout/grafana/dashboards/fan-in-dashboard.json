          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT class_name AS \"Class\", fan_in AS \"Fan-In\"\nFROM fan_in_metrics\nWHERE recorded_at = (SELECT MAX(recorded_at) FROM fan_in_metrics)\n  AND fan_in >= ${min_fanin}\n  AND class_name LIKE '%${class_filter}%'\nORDER BY fan_in DESC;",
          "refId": "A"
